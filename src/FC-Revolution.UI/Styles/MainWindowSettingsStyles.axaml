<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="StackPanel.settings-tab-content">
        <Setter Property="Margin" Value="0,16,0,0"/>
        <Setter Property="Spacing" Value="16"/>
    </Style>
    <Style Selector="Border.settings-tab-header">
        <Setter Property="Width" Value="64"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Margin" Value="-8,0,0,0"/>
    </Style>
    <Style Selector="Border.settings-summary-card">
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Background" Value="#241914"/>
        <Setter Property="BorderBrush" Value="#5A3F2E"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.settings-card">
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Background" Value="#261A14"/>
        <Setter Property="BorderBrush" Value="#5A3F2E"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Border.settings-subcard">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="#1C1310"/>
        <Setter Property="BorderBrush" Value="#5A3F2E"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10"/>
    </Style>
    <Style Selector="CheckBox.settings-toggle">
        <Setter Property="Foreground" Value="#EADCC8"/>
    </Style>
</Styles>
