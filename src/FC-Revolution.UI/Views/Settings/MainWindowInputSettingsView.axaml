<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.Settings.MainWindowInputSettingsView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Classes="settings-tab-content">
        <Border Classes="settings-card">
            <StackPanel Spacing="14">
                <StackPanel Spacing="12">
                    <TextBlock Classes="hero" FontSize="18" Text="全局按键配置"/>
                    <TextBlock Classes="label" FontSize="12" Text="使用手柄面板直接采集键位。1P 为浅灰手柄，2P 为深灰手柄。" TextWrapping="Wrap"/>
                    <Button Classes="chrome" Content="应用全局按键" Command="{Binding ApplyGlobalInputBindingsCommand}" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="14">
                    <Border CornerRadius="18" Padding="14" Background="#D7D7D7" BorderBrush="#8A8A8A" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="hero" FontSize="16" Foreground="#2A2623" Text="1P"/>
                            <Viewbox Height="210" Stretch="Uniform" HorizontalAlignment="Stretch">
                                <Grid Width="356" Height="150">
                                    <Canvas Width="356" Height="150">
                                        <Border Width="356" Height="150" CornerRadius="28" Background="#ECECEC" BorderBrush="#989898" BorderThickness="5"/>
                                        <Border Width="104" Height="24" CornerRadius="10" Background="#C9C9C9" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#D6D6D6" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#D6D6D6" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}"/>
                                        <Border Width="66" Height="27" Background="#575757" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}"/>
                                        <Border Width="27" Height="66" Background="#575757" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#C34D4D" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#C34D4D" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#8A8A8A" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#8A8A8A" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}"/>
                                    </Canvas>
                                    <ItemsControl ItemsSource="{Binding GlobalInputBindingsPlayer1}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid Width="356" Height="150"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Width="{Binding EditorWidth}"
                                                        Height="{Binding EditorHeight}"
                                                        Margin="{Binding EditorMargin}"
                                                        Padding="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Focusable="True"
                                                        Background="#FFF8EF"
                                                        BorderBrush="#75685D"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Text="{Binding SelectedKeyDisplay}"
                                                                   Foreground="#1F1A17"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Viewbox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>
                            <Border Classes="binding-extra-panel">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="label" FontSize="11" Foreground="#2A2623" Text="连发键 / 组合键"/>
                                        <Button Grid.Column="1" Classes="subtle binding-mini" Content="+ 连发" Command="{Binding DataContext.AddGlobalTurboBindingCommand, ElementName=RootWindow}" CommandParameter="0"/>
                                        <Button Grid.Column="2" Classes="subtle binding-mini" Content="+ 组合" Command="{Binding DataContext.AddGlobalComboBindingCommand, ElementName=RootWindow}" CommandParameter="0"/>
                                    </Grid>
                                    <TextBlock Classes="label" FontSize="10" Foreground="#4C4035" Text="扩展键不会改变手柄原始布局，会附加在手柄下方的列表中。" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding DataContext.GlobalExtraInputBindingsPlayer1, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                <Border Classes="binding-extra-row" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                        <Border CornerRadius="6" Padding="5,2" Background="#D4C9B8" VerticalAlignment="Center">
                                                            <TextBlock Classes="label" FontSize="10" Foreground="#2A2623" Text="{Binding KindLabel}"/>
                                                        </Border>
                                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="3" VerticalAlignment="Center">
                                                            <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="model:ComboChipItem">
                                                                        <Border CornerRadius="8" Padding="5,2" Background="#C8BBAA" BorderBrush="#A89888" BorderThickness="1">
                                                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#2A2623" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border IsVisible="{Binding IsTurbo}"
                                                                    CornerRadius="8"
                                                                    Width="60"
                                                                    Padding="5,2"
                                                                    Background="#C8BBAA"
                                                                    BorderBrush="#A89888"
                                                                    BorderThickness="1"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#2A2623" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Grid Grid.Column="1">
                                                                <ToggleButton x:Name="GlobalPlayer1PickerButton"
                                                                              Content="+"
                                                                              Classes="binding-picker launcher"
                                                                              IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                <Popup PlacementTarget="{Binding #GlobalPlayer1PickerButton}"
                                                                       Placement="BottomEdgeAlignedLeft"
                                                                       HorizontalOffset="0"
                                                                       VerticalOffset="8"
                                                                       IsLightDismissEnabled="True"
                                                                       IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                    <Border Classes="binding-picker-popup">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="label" FontSize="10" Foreground="#D8C2A9" Text="{Binding ButtonPickerHintText}" TextWrapping="Wrap"/>
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <UniformGrid Columns="4"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Classes="binding-picker option"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2"
                                                                    IsVisible="{Binding IsTurbo}"
                                                                    Orientation="Horizontal"
                                                                    Spacing="2"
                                                                    VerticalAlignment="Center">
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="-"
                                                                    Command="{Binding DataContext.DecrGlobalTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Border CornerRadius="6" Padding="5,2" Background="#C8BBAA" BorderBrush="#A89888" BorderThickness="1" MinWidth="38" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#2A2623" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="+"
                                                                    Command="{Binding DataContext.IncrGlobalTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3"
                                                                CornerRadius="6"
                                                                BorderThickness="1"
                                                                BorderBrush="#8D8174"
                                                                Background="#FFFDF8"
                                                                Padding="5,3"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Focusable="True"
                                                                PointerPressed="OnInputBindingBoxPointerPressed"
                                                                GotFocus="OnInputBindingBoxGotFocus"
                                                                LostFocus="OnInputBindingBoxLostFocus"
                                                                KeyDown="OnInputBindingBoxKeyDown">
                                                            <Viewbox Stretch="Uniform" Height="14">
                                                                <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#1F1A17" HorizontalAlignment="Center"/>
                                                            </Viewbox>
                                                        </Border>
                                                        <Button Grid.Column="4" Classes="subtle binding-mini" Content="删除" Command="{Binding DataContext.RemoveGlobalExtraBindingCommand, ElementName=RootWindow}" CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="18" Padding="14" Background="#555555" BorderBrush="#2E2E2E" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="hero" FontSize="16" Foreground="#F2E8D8" Text="2P"/>
                            <Viewbox Height="210" Stretch="Uniform" HorizontalAlignment="Stretch">
                                <Grid Width="356" Height="150">
                                    <Canvas Width="356" Height="150">
                                        <Border Width="356" Height="150" CornerRadius="28" Background="#707070" BorderBrush="#2F2F2F" BorderThickness="5"/>
                                        <Border Width="104" Height="24" CornerRadius="10" Background="#5A5A5A" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#626262" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#626262" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}"/>
                                        <Border Width="66" Height="27" Background="#ECE2D1" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}"/>
                                        <Border Width="27" Height="66" Background="#ECE2D1" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#D8736D" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#D8736D" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#D0C6B8" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#D0C6B8" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}"/>
                                    </Canvas>
                                    <ItemsControl ItemsSource="{Binding GlobalInputBindingsPlayer2}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid Width="356" Height="150"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Width="{Binding EditorWidth}"
                                                        Height="{Binding EditorHeight}"
                                                        Margin="{Binding EditorMargin}"
                                                        Padding="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Focusable="True"
                                                        Background="#221A16"
                                                        BorderBrush="#C7B49B"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Text="{Binding SelectedKeyDisplay}"
                                                                   Foreground="#F7ECDD"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Viewbox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>
                            <Border Classes="binding-extra-panel dark">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="label" FontSize="11" Foreground="#F2E8D8" Text="连发键 / 组合键"/>
                                        <Button Grid.Column="1" Classes="subtle binding-mini" Content="+ 连发" Command="{Binding DataContext.AddGlobalTurboBindingCommand, ElementName=RootWindow}" CommandParameter="1"/>
                                        <Button Grid.Column="2" Classes="subtle binding-mini" Content="+ 组合" Command="{Binding DataContext.AddGlobalComboBindingCommand, ElementName=RootWindow}" CommandParameter="1"/>
                                    </Grid>
                                    <TextBlock Classes="label" FontSize="10" Foreground="#CDB9A3" Text="额外按键会和基础键位一起生效，适合连发和预设组合。" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding DataContext.GlobalExtraInputBindingsPlayer2, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                <Border Classes="binding-extra-row dark" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="5">
                                                        <Border CornerRadius="6" Padding="5,2" Background="#3D2E26" VerticalAlignment="Center">
                                                            <TextBlock Classes="label" FontSize="10" Foreground="#F2E8D8" Text="{Binding KindLabel}"/>
                                                        </Border>
                                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="3" VerticalAlignment="Center">
                                                            <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="model:ComboChipItem">
                                                                        <Border CornerRadius="8" Padding="5,2" Background="#4A3628" BorderBrush="#7A5E4A" BorderThickness="1">
                                                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#F2E8D8" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border IsVisible="{Binding IsTurbo}"
                                                                    CornerRadius="8"
                                                                    Width="60"
                                                                    Padding="5,2"
                                                                    Background="#4A3628"
                                                                    BorderBrush="#7A5E4A"
                                                                    BorderThickness="1"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#F2E8D8" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Grid Grid.Column="1">
                                                                <ToggleButton x:Name="GlobalPlayer2PickerButton"
                                                                              Content="+"
                                                                              Classes="binding-picker launcher"
                                                                              IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                <Popup PlacementTarget="{Binding #GlobalPlayer2PickerButton}"
                                                                       Placement="BottomEdgeAlignedLeft"
                                                                       HorizontalOffset="0"
                                                                       VerticalOffset="8"
                                                                       IsLightDismissEnabled="True"
                                                                       IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                    <Border Classes="binding-picker-popup">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="label" FontSize="10" Foreground="#D8C2A9" Text="{Binding ButtonPickerHintText}" TextWrapping="Wrap"/>
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <UniformGrid Columns="4"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Classes="binding-picker option"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </Grid>
                                                        <Border Grid.Column="2"
                                                                CornerRadius="6"
                                                                BorderThickness="1"
                                                                BorderBrush="#8D8174"
                                                                Background="#1B1512"
                                                                Padding="5,3"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Focusable="True"
                                                                PointerPressed="OnInputBindingBoxPointerPressed"
                                                                GotFocus="OnInputBindingBoxGotFocus"
                                                                LostFocus="OnInputBindingBoxLostFocus"
                                                                KeyDown="OnInputBindingBoxKeyDown">
                                                            <Viewbox Stretch="Uniform" Height="14">
                                                                <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#F7ECDD" HorizontalAlignment="Center"/>
                                                            </Viewbox>
                                                        </Border>
                                                        <Button Grid.Column="3" Classes="subtle binding-mini" Content="删除" Command="{Binding DataContext.RemoveGlobalExtraBindingCommand, ElementName=RootWindow}" CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="14">
                <StackPanel Spacing="12">
                    <TextBlock Classes="hero" FontSize="18" Text="当前游戏独立按键"/>
                    <TextBlock Classes="label" FontSize="12" Text="{Binding RomInputOverrideSummary}" TextWrapping="Wrap"/>
                    <TextBlock Classes="label" FontSize="12" Text="独立配置使用另一套手柄外观：1P 为浅黑，2P 为白色。" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="subtle" Content="启用独立配置" Command="{Binding EnableRomInputOverrideCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                        <Button Classes="subtle" Content="清除独立配置" Command="{Binding ClearRomInputOverrideCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                    </StackPanel>
                    <Button Classes="chrome"
                            Content="保存当前游戏独立按键"
                            Command="{Binding ApplyRomInputOverrideCommand}"
                            IsEnabled="{Binding IsRomInputOverrideEnabled}"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Spacing="14">
                    <Border CornerRadius="18" Padding="14" Background="#252120" BorderBrush="#514746" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="hero" FontSize="16" Foreground="#F4EBDD" Text="1P 独立"/>
                            <Viewbox Height="210" Stretch="Uniform" HorizontalAlignment="Stretch">
                                <Grid Width="356" Height="150">
                                    <Canvas Width="356" Height="150">
                                        <Border Width="356" Height="150" CornerRadius="28" Background="#34302F" BorderBrush="#5A5352" BorderThickness="5"/>
                                        <Border Width="104" Height="24" CornerRadius="10" Background="#2A2625" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#2D2928" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#2D2928" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}"/>
                                        <Border Width="66" Height="27" Background="#E9DDCB" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}"/>
                                        <Border Width="27" Height="66" Background="#E9DDCB" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#C96B66" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#C96B66" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#B7AC9C" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#B7AC9C" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}"/>
                                    </Canvas>
                                    <ItemsControl ItemsSource="{Binding RomInputBindingsPlayer1}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid Width="356" Height="150"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Width="{Binding EditorWidth}"
                                                        Height="{Binding EditorHeight}"
                                                        Margin="{Binding EditorMargin}"
                                                        Padding="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Focusable="True"
                                                        IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                        Background="#120F0E"
                                                        BorderBrush="#8B7A6A"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Text="{Binding SelectedKeyDisplay}"
                                                                   Foreground="#F7ECDD"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Viewbox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>
                            <Border Classes="binding-extra-panel rom-dark">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="label" FontSize="11" Foreground="#F4EBDD" Text="连发键 / 组合键"/>
                                        <Button Grid.Column="1" Classes="subtle binding-mini" Content="+ 连发" Command="{Binding DataContext.AddRomTurboBindingCommand, ElementName=RootWindow}" CommandParameter="0" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                        <Button Grid.Column="2" Classes="subtle binding-mini" Content="+ 组合" Command="{Binding DataContext.AddRomComboBindingCommand, ElementName=RootWindow}" CommandParameter="0" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                    </Grid>
                                    <TextBlock Classes="label" FontSize="10" Foreground="#CDB9A3" Text="ROM 独立扩展键也会一并保存。新增时会自动启用当前游戏的独立配置。" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding DataContext.RomExtraInputBindingsPlayer1, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                <Border Classes="binding-extra-row rom-dark" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                        <Border CornerRadius="6" Padding="5,2" Background="#2D2420" VerticalAlignment="Center">
                                                            <TextBlock Classes="label" FontSize="10" Foreground="#F4EBDD" Text="{Binding KindLabel}"/>
                                                        </Border>
                                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="3" VerticalAlignment="Center" IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}">
                                                            <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="model:ComboChipItem">
                                                                        <Border CornerRadius="8" Padding="5,2" Background="#352B24" BorderBrush="#6B5D52" BorderThickness="1">
                                                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#F4EBDD" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border IsVisible="{Binding IsTurbo}"
                                                                    CornerRadius="8"
                                                                    Width="60"
                                                                    Padding="5,2"
                                                                    Background="#352B24"
                                                                    BorderBrush="#6B5D52"
                                                                    BorderThickness="1"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#F4EBDD" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Grid Grid.Column="1">
                                                                <ToggleButton x:Name="RomPlayer1PickerButton"
                                                                              Content="+"
                                                                              Classes="binding-picker launcher"
                                                                              IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                              IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                <Popup PlacementTarget="{Binding #RomPlayer1PickerButton}"
                                                                       Placement="BottomEdgeAlignedLeft"
                                                                       HorizontalOffset="0"
                                                                       VerticalOffset="8"
                                                                       IsLightDismissEnabled="True"
                                                                       IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                    <Border Classes="binding-picker-popup">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="label" FontSize="10" Foreground="#D8C2A9" Text="{Binding ButtonPickerHintText}" TextWrapping="Wrap"/>
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <UniformGrid Columns="4"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Classes="binding-picker option"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2"
                                                                    IsVisible="{Binding IsTurbo}"
                                                                    Orientation="Horizontal"
                                                                    Spacing="2"
                                                                    VerticalAlignment="Center"
                                                                    IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}">
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="-"
                                                                    Command="{Binding DataContext.DecrRomTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Border CornerRadius="6" Padding="5,2" Background="#352B24" BorderBrush="#6B5D52" BorderThickness="1" MinWidth="38" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#F4EBDD" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="+"
                                                                    Command="{Binding DataContext.IncrRomTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3"
                                                                CornerRadius="6"
                                                                BorderThickness="1"
                                                                BorderBrush="#8D8174"
                                                                Background="#120F0E"
                                                                Padding="5,3"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Focusable="True"
                                                                IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                PointerPressed="OnInputBindingBoxPointerPressed"
                                                                GotFocus="OnInputBindingBoxGotFocus"
                                                                LostFocus="OnInputBindingBoxLostFocus"
                                                                KeyDown="OnInputBindingBoxKeyDown">
                                                            <Viewbox Stretch="Uniform" Height="14">
                                                                <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#F7ECDD" HorizontalAlignment="Center"/>
                                                            </Viewbox>
                                                        </Border>
                                                        <Button Grid.Column="4" Classes="subtle binding-mini" Content="删除" Command="{Binding DataContext.RemoveRomExtraBindingCommand, ElementName=RootWindow}" CommandParameter="{Binding}" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="18" Padding="14" Background="#F3EFE8" BorderBrush="#B2AAA0" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="hero" FontSize="16" Foreground="#1F1A17" Text="2P 独立"/>
                            <Viewbox Height="210" Stretch="Uniform" HorizontalAlignment="Stretch">
                                <Grid Width="356" Height="150">
                                    <Canvas Width="356" Height="150">
                                        <Border Width="356" Height="150" CornerRadius="28" Background="#FFFFFF" BorderBrush="#CBC4BA" BorderThickness="5"/>
                                        <Border Width="104" Height="24" CornerRadius="10" Background="#E5DED3" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#ECE6DD" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="87" Height="87" Fill="#ECE6DD" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}"/>
                                        <Border Width="66" Height="27" Background="#5A544D" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}"/>
                                        <Border Width="27" Height="66" Background="#5A544D" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#D56F68" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="27" Height="27" Fill="#D56F68" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#9C9388" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}"/>
                                        <Ellipse Width="18" Height="18" Fill="#9C9388" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}"/>
                                    </Canvas>
                                    <ItemsControl ItemsSource="{Binding RomInputBindingsPlayer2}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Grid Width="356" Height="150"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Width="{Binding EditorWidth}"
                                                        Height="{Binding EditorHeight}"
                                                        Margin="{Binding EditorMargin}"
                                                        Padding="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Focusable="True"
                                                        IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                        Background="#FFF9F0"
                                                        BorderBrush="#8D8174"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Text="{Binding SelectedKeyDisplay}"
                                                                   Foreground="#1F1A17"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Viewbox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>
                            <Border Classes="binding-extra-panel rom-light">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="label" FontSize="11" Foreground="#1F1A17" Text="连发键 / 组合键"/>
                                        <Button Grid.Column="1" Classes="subtle binding-mini" Content="+ 连发" Command="{Binding DataContext.AddRomTurboBindingCommand, ElementName=RootWindow}" CommandParameter="1" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                        <Button Grid.Column="2" Classes="subtle binding-mini" Content="+ 组合" Command="{Binding DataContext.AddRomComboBindingCommand, ElementName=RootWindow}" CommandParameter="1" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                    </Grid>
                                    <TextBlock Classes="label" FontSize="10" Foreground="#5F5447" Text="把额外键位放在控制器下方，不会挤占原本 8 个主按键的位置。" TextWrapping="Wrap"/>
                                    <ItemsControl ItemsSource="{Binding DataContext.RomExtraInputBindingsPlayer2, ElementName=RootWindow}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                <Border Classes="binding-extra-row rom-light" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                        <Border CornerRadius="6" Padding="5,2" Background="#E8DDD0" VerticalAlignment="Center">
                                                            <TextBlock Classes="label" FontSize="10" Foreground="#1F1A17" Text="{Binding KindLabel}"/>
                                                        </Border>
                                                        <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="3" VerticalAlignment="Center" IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}">
                                                            <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="model:ComboChipItem">
                                                                        <Border CornerRadius="8" Padding="5,2" Background="#DDD1C4" BorderBrush="#C0B3A4" BorderThickness="1">
                                                                            <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#1F1A17" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border IsVisible="{Binding IsTurbo}"
                                                                    CornerRadius="8"
                                                                    Width="60"
                                                                    Padding="5,2"
                                                                    Background="#DDD1C4"
                                                                    BorderBrush="#C0B3A4"
                                                                    BorderThickness="1"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#1F1A17" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Grid Grid.Column="1">
                                                                <ToggleButton x:Name="RomPlayer2PickerButton"
                                                                              Content="+"
                                                                              Classes="binding-picker launcher"
                                                                              IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                              IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                <Popup PlacementTarget="{Binding #RomPlayer2PickerButton}"
                                                                       Placement="BottomEdgeAlignedLeft"
                                                                       HorizontalOffset="0"
                                                                       VerticalOffset="8"
                                                                       IsLightDismissEnabled="True"
                                                                       IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                    <Border Classes="binding-picker-popup">
                                                                        <StackPanel Spacing="8">
                                                                            <TextBlock Classes="label" FontSize="10" Foreground="#D8C2A9" Text="{Binding ButtonPickerHintText}" TextWrapping="Wrap"/>
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <UniformGrid Columns="4"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Classes="binding-picker option"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2"
                                                                    IsVisible="{Binding IsTurbo}"
                                                                    Orientation="Horizontal"
                                                                    Spacing="2"
                                                                    VerticalAlignment="Center"
                                                                    IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}">
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="-"
                                                                    Command="{Binding DataContext.DecrRomTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                            <Border CornerRadius="6" Padding="5,2" Background="#DDD1C4" BorderBrush="#C0B3A4" BorderThickness="1" MinWidth="38" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#1F1A17" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                            </Border>
                                                            <Button Classes="subtle binding-mini"
                                                                    Content="+"
                                                                    Command="{Binding DataContext.IncrRomTurboHzCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="3"
                                                                CornerRadius="6"
                                                                BorderThickness="1"
                                                                BorderBrush="#8D8174"
                                                                Background="#FFF9F0"
                                                                Padding="5,3"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Focusable="True"
                                                                IsEnabled="{Binding DataContext.IsRomInputOverrideEnabled, ElementName=RootWindow}"
                                                                PointerPressed="OnInputBindingBoxPointerPressed"
                                                                GotFocus="OnInputBindingBoxGotFocus"
                                                                LostFocus="OnInputBindingBoxLostFocus"
                                                                KeyDown="OnInputBindingBoxKeyDown">
                                                            <Viewbox Stretch="Uniform" Height="14">
                                                                <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#1F1A17" HorizontalAlignment="Center"/>
                                                            </Viewbox>
                                                        </Border>
                                                        <Button Grid.Column="4" Classes="subtle binding-mini" Content="删除" Command="{Binding DataContext.RemoveRomExtraBindingCommand, ElementName=RootWindow}" CommandParameter="{Binding}" IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="hero" FontSize="18" Text="手柄布局调试"/>
                        <TextBlock Classes="label" FontSize="12" Text="{Binding InputLayoutDebugSummary}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="subtle" Content="重置默认布局" Command="{Binding ResetInputBindingLayoutCommand}"/>
                </Grid>

                <Border CornerRadius="18" Padding="18" Background="#1C1411" BorderBrush="#6A4C36" BorderThickness="1">
                    <Grid HorizontalAlignment="Center">
                        <Grid x:Name="InputLayoutDebugSurface" Width="356" Height="150">
                            <Canvas Width="356" Height="150">
                                <Border Width="356" Height="150" CornerRadius="28" Background="#ECECEC" BorderBrush="#989898" BorderThickness="5"/>
                                <Border Width="104" Height="24" CornerRadius="10" Background="#C9C9C9" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="87" Height="87" Fill="#D6D6D6" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="87" Height="87" Fill="#D6D6D6" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}"/>
                                <Border Width="66" Height="27" Background="#575757" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}"/>
                                <Border Width="27" Height="66" Background="#575757" CornerRadius="6" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="27" Height="27" Fill="#C34D4D" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="27" Height="27" Fill="#C34D4D" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="18" Height="18" Fill="#8A8A8A" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}"/>
                                <Ellipse Width="18" Height="18" Fill="#8A8A8A" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}"/>
                            </Canvas>
                            <Canvas Width="356" Height="150">
                                <Border Width="104" Height="24" Margin="{Binding DataContext.InputLayoutBridgeMargin, ElementName=RootWindow}" BorderBrush="#33A3FF" BorderThickness="1" Background="#2233A3FF" Tag="Bridge" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="87" Height="87" Margin="{Binding DataContext.InputLayoutLeftCircleMargin, ElementName=RootWindow}" BorderBrush="#33A3FF" BorderThickness="1" Background="#1433A3FF" CornerRadius="44" Tag="LeftCircle" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="66" Height="27" Margin="{Binding DataContext.InputLayoutDPadHorizontalMargin, ElementName=RootWindow}" BorderBrush="#33A3FF" BorderThickness="1" Background="#1433A3FF" Tag="DPadHorizontal" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="27" Height="66" Margin="{Binding DataContext.InputLayoutDPadVerticalMargin, ElementName=RootWindow}" BorderBrush="#33A3FF" BorderThickness="1" Background="#1433A3FF" Tag="DPadVertical" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="87" Height="87" Margin="{Binding DataContext.InputLayoutRightCircleMargin, ElementName=RootWindow}" BorderBrush="#FF6A3D" BorderThickness="1" Background="#14FF6A3D" CornerRadius="44" Tag="RightCircle" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="27" Height="27" Margin="{Binding DataContext.InputLayoutBDecorationMargin, ElementName=RootWindow}" BorderBrush="#FF6A3D" BorderThickness="1" Background="#22FF6A3D" CornerRadius="14" Tag="BDecoration" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="27" Height="27" Margin="{Binding DataContext.InputLayoutADecorationMargin, ElementName=RootWindow}" BorderBrush="#FF6A3D" BorderThickness="1" Background="#22FF6A3D" CornerRadius="14" Tag="ADecoration" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="18" Height="18" Margin="{Binding DataContext.InputLayoutSelectDecorationMargin, ElementName=RootWindow}" BorderBrush="#F6E27A" BorderThickness="1" Background="#22F6E27A" CornerRadius="9" Tag="SelectDecoration" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                                <Border Width="18" Height="18" Margin="{Binding DataContext.InputLayoutStartDecorationMargin, ElementName=RootWindow}" BorderBrush="#F6E27A" BorderThickness="1" Background="#22F6E27A" CornerRadius="9" Tag="StartDecoration" PointerPressed="OnDebugDecorationPointerPressed" PointerMoved="OnDebugDecorationPointerMoved" PointerReleased="OnDebugDecorationPointerReleased"/>
                            </Canvas>
                            <ItemsControl ItemsSource="{Binding InputLayoutDebugBindings}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid Width="356" Height="150"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:InputBindingEntry">
                                        <Border Width="{Binding EditorWidth}"
                                                Height="{Binding EditorHeight}"
                                                Margin="{Binding EditorMargin}"
                                                Padding="1"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Background="#D9F96B"
                                                BorderBrush="#283000"
                                                PointerPressed="OnDebugInputBindingPointerPressed"
                                                PointerMoved="OnDebugInputBindingPointerMoved"
                                                PointerReleased="OnDebugInputBindingPointerReleased">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Text="{Binding ActionName}"
                                                           Foreground="#111300"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Classes="label" FontSize="11" Text="拖动绿色框即可校准位置。这里改的是统一布局模型，不会重新启用运行期调试浮层。" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
