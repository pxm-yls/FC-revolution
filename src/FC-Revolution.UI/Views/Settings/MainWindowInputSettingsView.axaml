<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.Settings.MainWindowInputSettingsView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Classes="settings-tab-content" Spacing="16">
        <Border Classes="settings-card">
            <StackPanel Spacing="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="hero" FontSize="18" Text="全局按键配置"/>
                        <TextBlock Classes="label" FontSize="12" Text="按端口分组维护基础键位、连发和组合键。按键捕获与运行时输入都走统一的 portId / actionId 语义。" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Classes="chrome" Content="应用全局按键" Command="{Binding ApplyGlobalInputBindingsCommand}" HorizontalAlignment="Right"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding GlobalInputPortGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="420" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="model:InputBindingPortGroup">
                            <Border Margin="0,0,16,16" Padding="14" CornerRadius="18" Background="#F7F0E5" BorderBrush="#C4B6A3" BorderThickness="1" MinWidth="390">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="hero" FontSize="16" Text="{Binding PortLabel}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Classes="subtle binding-mini"
                                                Content="+ 连发"
                                                Command="{Binding DataContext.AddGlobalTurboBindingCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding PortId}"/>
                                        <Button Grid.Column="2"
                                                Classes="subtle binding-mini"
                                                Content="+ 组合"
                                                Command="{Binding DataContext.AddGlobalComboBindingCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding PortId}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding InputBindings}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Margin="0,0,8,8"
                                                        Padding="8"
                                                        Width="118"
                                                        CornerRadius="10"
                                                        BorderThickness="1"
                                                        BorderBrush="#8D8174"
                                                        Background="#FFF9F0"
                                                        Focusable="True"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Classes="label" FontSize="11" Text="{Binding ActionName}" TextWrapping="Wrap"/>
                                                        <TextBlock Classes="hero" FontSize="14" Text="{Binding SelectedKeyDisplay}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Classes="binding-extra-panel">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="label" FontSize="11" Text="扩展按键"/>
                                            <ItemsControl ItemsSource="{Binding ExtraBindings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                        <Border Classes="binding-extra-row" Margin="0,0,0,6">
                                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                                <Border CornerRadius="6" Padding="5,2" Background="#D4C9B8" VerticalAlignment="Center">
                                                                    <TextBlock Classes="label" FontSize="10" Foreground="#2A2623" Text="{Binding KindLabel}"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                    <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="model:ComboChipItem">
                                                                                <Border CornerRadius="8" Padding="5,2" Background="#C8BBAA" BorderBrush="#A89888" BorderThickness="1">
                                                                                    <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#2A2623"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <Border IsVisible="{Binding IsTurbo}"
                                                                            CornerRadius="8"
                                                                            Padding="5,2"
                                                                            Background="#C8BBAA"
                                                                            BorderBrush="#A89888"
                                                                            BorderThickness="1">
                                                                        <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#2A2623"/>
                                                                    </Border>
                                                                    <ToggleButton x:Name="GlobalExtraPickerButton"
                                                                                  Content="按钮"
                                                                                  Classes="subtle binding-mini"
                                                                                  IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                    <Popup PlacementTarget="{Binding #GlobalExtraPickerButton}"
                                                                           Placement="BottomEdgeAlignedLeft"
                                                                           HorizontalOffset="0"
                                                                           VerticalOffset="8"
                                                                           IsLightDismissEnabled="True"
                                                                           IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                        <Border Padding="10" CornerRadius="12" Background="#FFF9F0" BorderBrush="#B7A28D" BorderThickness="1">
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Border>
                                                                    </Popup>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2" IsVisible="{Binding IsTurbo}" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                                    <Button Classes="subtle binding-mini"
                                                                            Content="-"
                                                                            Command="{Binding DataContext.DecrGlobalTurboHzCommand, ElementName=RootWindow}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <Border CornerRadius="6" Padding="5,2" Background="#C8BBAA" BorderBrush="#A89888" BorderThickness="1" MinWidth="42" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#2A2623" HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                    <Button Classes="subtle binding-mini"
                                                                            Content="+"
                                                                            Command="{Binding DataContext.IncrGlobalTurboHzCommand, ElementName=RootWindow}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                                <Border Grid.Column="3"
                                                                        CornerRadius="6"
                                                                        BorderThickness="1"
                                                                        BorderBrush="#8D8174"
                                                                        Background="#FFFDF8"
                                                                        Padding="5,3"
                                                                        MinWidth="44"
                                                                        VerticalAlignment="Center"
                                                                        Focusable="True"
                                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                                    <TextBlock Text="{Binding SelectedKeyDisplay}" HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <Button Grid.Column="4"
                                                                        Classes="subtle binding-mini"
                                                                        Content="删除"
                                                                        Command="{Binding DataContext.RemoveGlobalExtraBindingCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Classes="hero" FontSize="18" Text="ROM 独立按键配置"/>
                    <TextBlock Classes="label" FontSize="12" Text="{Binding RomInputOverrideSummary}" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Classes="subtle" Content="启用独立配置" Command="{Binding EnableRomInputOverrideCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                    <Button Classes="subtle" Content="清除独立配置" Command="{Binding ClearRomInputOverrideCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                    <Button Classes="chrome" Content="应用 ROM 独立按键" Command="{Binding ApplyRomInputOverrideCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding RomInputPortGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="420" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="model:InputBindingPortGroup">
                            <Border Margin="0,0,16,16" Padding="14" CornerRadius="18" Background="#1D1816" BorderBrush="#6A4C36" BorderThickness="1" MinWidth="390">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                        <TextBlock Classes="hero" FontSize="16" Foreground="#F4EBDD" Text="{Binding PortLabel}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Classes="subtle binding-mini"
                                                Content="+ 连发"
                                                Command="{Binding DataContext.AddRomTurboBindingCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding PortId}"
                                                IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                        <Button Grid.Column="2"
                                                Classes="subtle binding-mini"
                                                Content="+ 组合"
                                                Command="{Binding DataContext.AddRomComboBindingCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding PortId}"
                                                IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding InputBindings}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingEntry">
                                                <Border Margin="0,0,8,8"
                                                        Padding="8"
                                                        Width="118"
                                                        CornerRadius="10"
                                                        BorderThickness="1"
                                                        BorderBrush="#8B7A6A"
                                                        Background="#120F0E"
                                                        Focusable="True"
                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Classes="label" FontSize="11" Foreground="#D7C3AC" Text="{Binding ActionName}" TextWrapping="Wrap"/>
                                                        <TextBlock Classes="hero" FontSize="14" Foreground="#F7ECDD" Text="{Binding SelectedKeyDisplay}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Classes="binding-extra-panel dark">
                                        <StackPanel Spacing="8">
                                            <TextBlock Classes="label" FontSize="11" Foreground="#F4EBDD" Text="扩展按键"/>
                                            <ItemsControl ItemsSource="{Binding ExtraBindings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                        <Border Classes="binding-extra-row dark" Margin="0,0,0,6">
                                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                                <Border CornerRadius="6" Padding="5,2" Background="#3D2E26" VerticalAlignment="Center">
                                                                    <TextBlock Classes="label" FontSize="10" Foreground="#F4EBDD" Text="{Binding KindLabel}"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                    <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="model:ComboChipItem">
                                                                                <Border CornerRadius="8" Padding="5,2" Background="#4E3D33" BorderBrush="#8B6E5A" BorderThickness="1">
                                                                                    <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#F4EBDD"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <Border IsVisible="{Binding IsTurbo}"
                                                                            CornerRadius="8"
                                                                            Padding="5,2"
                                                                            Background="#4E3D33"
                                                                            BorderBrush="#8B6E5A"
                                                                            BorderThickness="1">
                                                                        <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#F4EBDD"/>
                                                                    </Border>
                                                                    <ToggleButton x:Name="RomExtraPickerButton"
                                                                                  Content="按钮"
                                                                                  Classes="subtle binding-mini"
                                                                                  IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                    <Popup PlacementTarget="{Binding #RomExtraPickerButton}"
                                                                           Placement="BottomEdgeAlignedLeft"
                                                                           HorizontalOffset="0"
                                                                           VerticalOffset="8"
                                                                           IsLightDismissEnabled="True"
                                                                           IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                        <Border Padding="10" CornerRadius="12" Background="#241D19" BorderBrush="#8B6E5A" BorderThickness="1">
                                                                            <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                        <ToggleButton Margin="0,0,6,6"
                                                                                                      Content="{Binding Label}"
                                                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                      Command="{Binding SelectCommand}"/>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Border>
                                                                    </Popup>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2" IsVisible="{Binding IsTurbo}" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                                    <Button Classes="subtle binding-mini"
                                                                            Content="-"
                                                                            Command="{Binding DataContext.DecrRomTurboHzCommand, ElementName=RootWindow}"
                                                                            CommandParameter="{Binding}"/>
                                                                    <Border CornerRadius="6" Padding="5,2" Background="#4E3D33" BorderBrush="#8B6E5A" BorderThickness="1" MinWidth="42" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#F4EBDD" HorizontalAlignment="Center"/>
                                                                    </Border>
                                                                    <Button Classes="subtle binding-mini"
                                                                            Content="+"
                                                                            Command="{Binding DataContext.IncrRomTurboHzCommand, ElementName=RootWindow}"
                                                                            CommandParameter="{Binding}"/>
                                                                </StackPanel>
                                                                <Border Grid.Column="3"
                                                                        CornerRadius="6"
                                                                        BorderThickness="1"
                                                                        BorderBrush="#8D8174"
                                                                        Background="#120F0E"
                                                                        Padding="5,3"
                                                                        MinWidth="44"
                                                                        VerticalAlignment="Center"
                                                                        Focusable="True"
                                                                        PointerPressed="OnInputBindingBoxPointerPressed"
                                                                        GotFocus="OnInputBindingBoxGotFocus"
                                                                        LostFocus="OnInputBindingBoxLostFocus"
                                                                        KeyDown="OnInputBindingBoxKeyDown">
                                                                    <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#F7ECDD" HorizontalAlignment="Center"/>
                                                                </Border>
                                                                <Button Grid.Column="4"
                                                                        Classes="subtle binding-mini"
                                                                        Content="删除"
                                                                        Command="{Binding DataContext.RemoveRomExtraBindingCommand, ElementName=RootWindow}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="hero" FontSize="18" Text="布局调试"/>
                        <TextBlock Classes="label" FontSize="12" Text="当前布局编辑仍作用于基础动作槽位；这里显示首个端口的槽位位置，便于微调与回归验证。" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Classes="subtle" Content="重置默认布局" Command="{Binding ResetInputBindingLayoutCommand}"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding InputLayoutDebugBindings}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="model:InputBindingEntry">
                            <Border Margin="0,0,8,8" Padding="8" CornerRadius="10" BorderBrush="#B7AB9C" BorderThickness="1" Background="#FFF9F0" Width="130">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="label" FontSize="11" Text="{Binding ActionName}"/>
                                    <TextBlock Classes="label" FontSize="10" Text="{Binding SelectedKeyDisplay}"/>
                                    <TextBlock Classes="label" FontSize="10" Text="{Binding EditorLeft, StringFormat='X {0:F0}'}"/>
                                    <TextBlock Classes="label" FontSize="10" Text="{Binding EditorTop, StringFormat='Y {0:F0}'}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
