<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:emulation="using:FCRevolution.Emulation.Abstractions"
             x:Class="FC_Revolution.UI.Views.Settings.MainWindowCoreSettingsView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Classes="settings-tab-content">
        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="核心选择与来源"/>
                <TextBlock Classes="label"
                           FontSize="12"
                           Text="这里集中管理默认模拟器核心、已安装核心包、导出/卸载入口，以及开发调试用的附加探测目录；所有变更只影响后续新建会话。"/>
                <TextBlock Classes="label"
                           FontSize="11"
                           Foreground="#A08060"
                           Text="{Binding InstalledCoreCatalogSummary}"
                           TextWrapping="Wrap"/>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" FontSize="12" Text="默认模拟器核心"/>
                    <ComboBox ItemsSource="{Binding InstalledCoreManifests}"
                              SelectedItem="{Binding SelectedDefaultCoreManifest}"
                              Width="360"
                              HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="emulation:CoreManifest">
                                <StackPanel Spacing="2">
                                    <TextBlock Classes="hero" FontSize="13" Text="{Binding DisplayName}"/>
                                    <TextBlock Classes="label"
                                               FontSize="11"
                                               Foreground="#A08060"
                                               Text="{Binding CoreId}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="{Binding DefaultCoreSummary}"
                               TextWrapping="Wrap"/>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="{Binding SelectedDefaultCoreSourceSummary}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <WrapPanel ItemWidth="156"
                           ItemHeight="92">
                    <Border Classes="settings-summary-card"
                            Width="148"
                            MinHeight="84">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" FontSize="11" Text="system"/>
                            <TextBlock Classes="hero" FontSize="16" Text="{Binding SelectedDefaultCoreSystemId}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="settings-summary-card"
                            Width="148"
                            MinHeight="84">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" FontSize="11" Text="version"/>
                            <TextBlock Classes="hero" FontSize="16" Text="{Binding SelectedDefaultCoreVersion}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="settings-summary-card"
                            Width="148"
                            MinHeight="84">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" FontSize="11" Text="binary"/>
                            <TextBlock Classes="hero" FontSize="16" Text="{Binding SelectedDefaultCoreBinaryKind}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="settings-summary-card"
                            Width="148"
                            MinHeight="84">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="label" FontSize="11" Text="来源 / 卸载"/>
                            <TextBlock Classes="hero"
                                       FontSize="16"
                                       Text="{Binding SelectedDefaultCoreSourceLabel}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="{Binding SelectedDefaultCoreRemovabilityLabel}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" FontSize="12" Text="安装位置 / 入口程序集"/>
                    <TextBox Classes="label"
                             FontSize="11"
                             Text="{Binding SelectedDefaultCoreAssemblyPathDisplay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             CaretBrush="#EADCC8"
                             Foreground="#EADCC8"/>
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                    <Border Classes="settings-subcard">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="hero" FontSize="14" Text="安装核心包"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="{Binding ManagedCoreInstallHint}"
                                       TextWrapping="Wrap"/>
                            <Button Classes="subtle"
                                    HorizontalAlignment="Left"
                                    Content="安装核心包"
                                    Command="{Binding InstallManagedCorePackageCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="settings-subcard">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="hero" FontSize="14" Text="导出所选核心"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="将当前选中核心重新打包为标准 *.fcrcore.zip，用于分发、迁移或备份。"
                                       TextWrapping="Wrap"/>
                            <Button Classes="subtle"
                                    HorizontalAlignment="Left"
                                    Content="导出核心包"
                                    Command="{Binding ExportSelectedManagedCorePackageCommand}"
                                    IsEnabled="{Binding CanExportSelectedManagedCore}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Classes="settings-subcard">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="hero" FontSize="14" Text="卸载当前核心"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="已安装核心包和旧版安装目录 DLL 支持直接卸载；内置核心与附加探测目录核心保持只读。"
                                       TextWrapping="Wrap"/>
                            <Button Classes="subtle"
                                    HorizontalAlignment="Left"
                                    Content="卸载所选核心"
                                    Command="{Binding UninstallSelectedManagedCoreCommand}"
                                    IsEnabled="{Binding CanUninstallSelectedManagedCore}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" FontSize="12" Text="附加开发探测目录"/>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="{Binding ManagedCoreProbePathsHint}"
                               TextWrapping="Wrap"/>
                    <TextBox Width="560"
                             MinHeight="88"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding ManagedCoreProbePathsInput}"
                             CaretBrush="#F7ECDD"
                             Background="#201612"
                             Foreground="#F7ECDD"
                             BorderBrush="#5A3F2E"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Classes="subtle" Content="应用目录" Command="{Binding ApplyManagedCoreProbePathsCommand}"/>
                        <Button Classes="subtle" Content="重新加载来源" Command="{Binding ReloadManagedCoreSourcesCommand}"/>
                    </StackPanel>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="{Binding ManagedCoreSourceSummary}"
                               TextWrapping="Wrap"/>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="{Binding ManagedCoreReloadHint}"
                               TextWrapping="Wrap"/>
                    <TextBox Classes="label"
                             FontSize="11"
                             Text="{Binding EffectiveManagedCoreProbeDirectoriesSummary}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             CaretBrush="#EADCC8"
                             Foreground="#EADCC8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="预留入口"/>
                <TextBlock Classes="label"
                           FontSize="12"
                           Text="当前只把未来核心管理的入口位置预留出来，不接联网更新、下载或版本切换逻辑。"/>
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Classes="settings-subcard">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="hero" FontSize="14" Text="版本管理（预留）"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="{Binding ManagedCoreVersionManagementHint}"
                                       TextWrapping="Wrap"/>
                            <Button Classes="subtle"
                                    HorizontalAlignment="Left"
                                    Content="切换版本（预留）"
                                    Command="{Binding OpenManagedCoreVersionManagementCommand}"
                                    IsEnabled="{Binding CanOpenManagedCoreVersionManagement}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="settings-subcard">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="hero" FontSize="14" Text="远程目录（预留）"/>
                            <TextBlock Classes="label"
                                       FontSize="11"
                                       Foreground="#A08060"
                                       Text="{Binding ManagedCoreRemoteCatalogHint}"
                                       TextWrapping="Wrap"/>
                            <Button Classes="subtle"
                                    HorizontalAlignment="Left"
                                    Content="检查更新（预留）"
                                    Command="{Binding OpenManagedCoreRemoteCatalogCommand}"
                                    IsEnabled="{Binding CanOpenManagedCoreRemoteCatalog}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
