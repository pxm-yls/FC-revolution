<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             x:Class="FC_Revolution.UI.Views.Settings.MainWindowLanSettingsView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Classes="settings-tab-content">
        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="局域网网页手柄"/>
                <TextBlock Classes="label" FontSize="12" Text="{Binding PreviewGenerationCompatibilitySummary}" TextWrapping="Wrap"/>
                <CheckBox Classes="settings-toggle" Content="启用局域网点播手柄" IsChecked="{Binding IsLanArcadeEnabled}"/>
                <CheckBox Classes="settings-toggle" Content="启用网页手柄页面与 WebSocket" IsChecked="{Binding IsLanArcadeWebPadEnabled}"/>
                <TextBlock Classes="label" FontSize="12" Text="{Binding LanArcadePortSummary}" TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="*,200" ColumnSpacing="14">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBox Width="120"
                                     Text="{Binding LanArcadePortInput}"
                                     CaretBrush="#F7ECDD"
                                     Background="#201612"
                                     Foreground="#F7ECDD"
                                     BorderBrush="#5A3F2E"/>
                            <Button Classes="subtle" Content="应用端口" Command="{Binding ApplyLanArcadePortCommand}"/>
                            <Button Classes="subtle" Content="打开首页" Command="{Binding OpenLanArcadeRootInBrowserCommand}"/>
                            <Button Classes="subtle" Content="内置网页探针" Command="{Binding OpenLanArcadeProbeWindowCommand}"/>
                        </StackPanel>
                        <TextBlock Classes="label" FontSize="12" Text="{Binding LanArcadeAccessSummary}" TextWrapping="Wrap"/>
                        <Border Classes="settings-subcard">
                            <TextBox Classes="label"
                                     FontSize="12"
                                     Text="{Binding LanArcadeControlSummary}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     CaretBrush="#EADCC8"
                                     Foreground="#EADCC8"/>
                        </Border>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="180"
                            Height="180"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="16"
                            Background="#FFF8F0"
                            BorderBrush="#5A3F2E"
                            BorderThickness="1"
                            Padding="10"
                            IsEnabled="{Binding IsLanArcadeEnabled}">
                        <Image Source="{Binding LanArcadeQrCode}" Stretch="Uniform"/>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="串流质量"/>
                <TextBlock Classes="label" FontSize="12" Text="{Binding LanStreamSummary}" TextWrapping="Wrap"/>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" FontSize="12" Text="分辨率倍率"/>
                    <ComboBox SelectedIndex="{Binding LanStreamScaleMultiplierIndex}"
                              IsEnabled="{Binding IsLanArcadeEnabled}"
                              Width="200"
                              HorizontalAlignment="Left">
                        <ComboBoxItem>1× — 原始 (256×240)</ComboBoxItem>
                        <ComboBoxItem>2× — 标准 (512×480)</ComboBoxItem>
                        <ComboBoxItem>3× — 高清 (768×720)</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="label" FontSize="12" Text="JPEG 质量"/>
                        <TextBlock Classes="label" FontSize="12" Text="{Binding LanStreamJpegQuality, StringFormat='{}{0} %'}"/>
                    </StackPanel>
                    <Slider Minimum="60"
                            Maximum="95"
                            Value="{Binding LanStreamJpegQuality}"
                            IsEnabled="{Binding IsLanArcadeEnabled}"
                            Width="300"
                            HorizontalAlignment="Left"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"/>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="60 = 低质高压缩 / 85 = 默认平衡 / 95 = 高质低压缩"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Classes="label" FontSize="12" Text="画面增强（串流端）"/>
                    <ComboBox SelectedIndex="{Binding LanStreamSharpenModeIndex}"
                              IsEnabled="{Binding IsLanArcadeEnabled}"
                              Width="200"
                              HorizontalAlignment="Left">
                        <ComboBoxItem>无</ComboBoxItem>
                        <ComboBoxItem>轻微锐化</ComboBoxItem>
                        <ComboBoxItem>CRT 扫描线</ComboBoxItem>
                        <ComboBoxItem>鲜艳色彩</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Classes="label"
                               FontSize="11"
                               Foreground="#A08060"
                               Text="NES 像素画建议：使用 2× 近邻插值 + 标准锐化，画面清晰且保留像素边缘。"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="访问与自检"/>
                <Border Classes="settings-subcard">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="hero" FontSize="14" Text="{Binding LanFirewallStatusTitle}" TextWrapping="Wrap"/>
                            <TextBlock Classes="label" FontSize="12" Text="{Binding LanFirewallStatusDetail}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="subtle" Content="刷新检测" Command="{Binding RefreshLanFirewallStatusCommand}"/>
                    </Grid>
                </Border>
                <Border Classes="settings-subcard">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Classes="hero" FontSize="14" Text="监听自检"/>
                            <Button Grid.Column="1" Classes="subtle" Content="刷新自检" Command="{Binding RefreshLanArcadeDiagnosticsCommand}"/>
                        </Grid>
                        <TextBox Classes="label"
                                 FontSize="12"
                                 Text="{Binding LanArcadeDiagnosticsText}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="160"
                                 MaxHeight="220"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 CaretBrush="#EADCC8"
                                 Foreground="#EADCC8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Classes="settings-card">
            <StackPanel Spacing="12">
                <TextBlock Classes="hero" FontSize="18" Text="资源清理"/>
                <TextBlock Classes="label" FontSize="12" Text="{Binding ResourceCleanupHint}" TextWrapping="Wrap"/>
                <TextBlock Classes="label" FontSize="12" Text="{Binding ResourceCleanupSummary}" TextWrapping="Wrap"/>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="10">
                    <Border Padding="12" CornerRadius="14" Background="#1A1210" BorderBrush="#5A3F2E" BorderThickness="1">
                        <CheckBox Content="预览动画" IsChecked="{Binding CleanupPreviewAnimationsSelected}" Foreground="#F7ECDD"/>
                    </Border>
                    <Border Grid.Column="1" Padding="12" CornerRadius="14" Background="#1A1210" BorderBrush="#5A3F2E" BorderThickness="1">
                        <CheckBox Content="缩略图 / 封面" IsChecked="{Binding CleanupThumbnailsSelected}" Foreground="#F7ECDD"/>
                    </Border>
                    <Border Grid.Row="1" Padding="12" CornerRadius="14" Background="#1A1210" BorderBrush="#5A3F2E" BorderThickness="1">
                        <CheckBox Content="时间线存档" IsChecked="{Binding CleanupTimelineSavesSelected}" Foreground="#F7ECDD"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Padding="12" CornerRadius="14" Background="#1A1210" BorderBrush="#5A3F2E" BorderThickness="1">
                        <CheckBox Content="导出视频" IsChecked="{Binding CleanupExportVideosSelected}" Foreground="#F7ECDD"/>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="subtle" Content="全选" Command="{Binding SelectAllCleanupTargetsCommand}"/>
                    <Button Classes="subtle" Content="清空选择" Command="{Binding ClearCleanupTargetSelectionCommand}"/>
                    <Button Classes="chrome"
                            Content="执行清理"
                            Command="{Binding ExecuteResourceCleanupCommand}"
                            IsEnabled="{Binding HasSelectedCleanupTargets}"/>
                </StackPanel>

                <Border CornerRadius="14"
                        Padding="12"
                        Background="#1A1210"
                        BorderBrush="#5A3F2E"
                        BorderThickness="1">
                    <TextBlock Classes="label" FontSize="12" Text="{Binding ResourceCleanupResultText}" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
