<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.MainWindowParts.MainWindowQuickRomInputEditorView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
    <ContentControl IsVisible="{Binding IsQuickRomInputEditorOpen}"
                    Content="{Binding QuickRomInputEditorContent}">
        <ContentControl.DataTemplates>
            <DataTemplate x:DataType="vm:MainWindowViewModel">
                <Border Background="#99000000"
                        PointerPressed="OnSettingsBackdropPressed">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="1040" MaxHeight="760">
                        <Border CornerRadius="24"
                                Padding="20"
                                Background="#181210"
                                BorderBrush="#6A4C36"
                                BorderThickness="1"
                                PointerPressed="OnSettingsCardPressed">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="hero" FontSize="24" Text="{Binding QuickRomInputEditorTitle}"/>
                                        <TextBlock Classes="label" FontSize="12" Text="这里按端口维护当前 ROM 的独立键位，不再把编辑器固定成 1P / 2P 双槽。" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button Classes="subtle" Content="清除独立按键" Command="{Binding ClearRomInputOverrideCommand}"/>
                                        <Button Classes="chrome" Content="保存" Command="{Binding SaveQuickRomInputEditorCommand}" IsEnabled="{Binding HasCurrentRom}"/>
                                        <Button Classes="subtle" Content="关闭" Command="{Binding CloseQuickRomInputEditorCommand}"/>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer MaxHeight="620">
                                    <ItemsControl ItemsSource="{Binding RomInputPortGroups}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemWidth="420" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="model:InputBindingPortGroup">
                                                <Border Margin="0,0,16,16" Padding="14" CornerRadius="18" Background="#241C19" BorderBrush="#6A4C36" BorderThickness="1" MinWidth="390">
                                                    <StackPanel Spacing="10">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                                            <TextBlock Classes="hero" FontSize="16" Foreground="#F4EBDD" Text="{Binding PortLabel}"/>
                                                            <Button Grid.Column="1"
                                                                    Classes="subtle binding-mini"
                                                                    Content="+ 连发"
                                                                    Command="{Binding DataContext.AddRomTurboBindingCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding PortId}"
                                                                    IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                                            <Button Grid.Column="2"
                                                                    Classes="subtle binding-mini"
                                                                    Content="+ 组合"
                                                                    Command="{Binding DataContext.AddRomComboBindingCommand, ElementName=RootWindow}"
                                                                    CommandParameter="{Binding PortId}"
                                                                    IsEnabled="{Binding DataContext.HasCurrentRom, ElementName=RootWindow}"/>
                                                        </Grid>

                                                        <ItemsControl ItemsSource="{Binding InputBindings}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="model:InputBindingEntry">
                                                                    <Border Margin="0,0,8,8"
                                                                            Padding="8"
                                                                            Width="118"
                                                                            CornerRadius="10"
                                                                            BorderThickness="1"
                                                                            BorderBrush="#8B7A6A"
                                                                            Background="#120F0E"
                                                                            Focusable="True"
                                                                            PointerPressed="OnInputBindingBoxPointerPressed"
                                                                            GotFocus="OnInputBindingBoxGotFocus"
                                                                            LostFocus="OnInputBindingBoxLostFocus"
                                                                            KeyDown="OnInputBindingBoxKeyDown">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Classes="label" FontSize="11" Foreground="#D7C3AC" Text="{Binding ActionName}" TextWrapping="Wrap"/>
                                                                            <TextBlock Classes="hero" FontSize="14" Foreground="#F7ECDD" Text="{Binding SelectedKeyDisplay}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <Border Classes="binding-extra-panel rom-dark">
                                                            <StackPanel Spacing="8">
                                                                <TextBlock Classes="label" FontSize="11" Foreground="#F4EBDD" Text="扩展按键"/>
                                                                <ItemsControl ItemsSource="{Binding ExtraBindings}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="model:ExtraInputBindingEntry">
                                                                            <Border Classes="binding-extra-row rom-dark" Margin="0,0,0,6">
                                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="5">
                                                                                    <Border CornerRadius="6" Padding="5,2" Background="#2D2420" VerticalAlignment="Center">
                                                                                        <TextBlock Classes="label" FontSize="10" Foreground="#F4EBDD" Text="{Binding KindLabel}"/>
                                                                                    </Border>
                                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                                        <ItemsControl ItemsSource="{Binding ComboChips}" IsVisible="{Binding IsCombo}">
                                                                                            <ItemsControl.ItemsPanel>
                                                                                                <ItemsPanelTemplate>
                                                                                                    <StackPanel Orientation="Horizontal" Spacing="3"/>
                                                                                                </ItemsPanelTemplate>
                                                                                            </ItemsControl.ItemsPanel>
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate x:DataType="model:ComboChipItem">
                                                                                                    <Border CornerRadius="8" Padding="5,2" Background="#4E3D33" BorderBrush="#8B6E5A" BorderThickness="1">
                                                                                                        <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#F4EBDD"/>
                                                                                                    </Border>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                        <Border IsVisible="{Binding IsTurbo}"
                                                                                                CornerRadius="8"
                                                                                                Padding="5,2"
                                                                                                Background="#4E3D33"
                                                                                                BorderBrush="#8B6E5A"
                                                                                                BorderThickness="1">
                                                                                            <TextBlock Text="{Binding PrimaryButtonOption.Label}" FontSize="10" Foreground="#F4EBDD"/>
                                                                                        </Border>
                                                                                        <ToggleButton x:Name="QuickRomExtraPickerButton"
                                                                                                      Content="按钮"
                                                                                                      Classes="subtle binding-mini"
                                                                                                      IsChecked="{Binding IsButtonPickerOpen, Mode=TwoWay}"/>
                                                                                        <Popup PlacementTarget="{Binding #QuickRomExtraPickerButton}"
                                                                                               Placement="BottomEdgeAlignedLeft"
                                                                                               HorizontalOffset="0"
                                                                                               VerticalOffset="8"
                                                                                               IsLightDismissEnabled="True"
                                                                                               IsOpen="{Binding IsButtonPickerOpen, Mode=TwoWay}">
                                                                                            <Border Padding="10" CornerRadius="12" Background="#241D19" BorderBrush="#8B6E5A" BorderThickness="1">
                                                                                                <ItemsControl ItemsSource="{Binding ButtonPickerItems}">
                                                                                                    <ItemsControl.ItemsPanel>
                                                                                                        <ItemsPanelTemplate>
                                                                                                            <WrapPanel Orientation="Horizontal"/>
                                                                                                        </ItemsPanelTemplate>
                                                                                                    </ItemsControl.ItemsPanel>
                                                                                                    <ItemsControl.ItemTemplate>
                                                                                                        <DataTemplate x:DataType="model:ExtraInputButtonPickerItem">
                                                                                                            <ToggleButton Margin="0,0,6,6"
                                                                                                                          Content="{Binding Label}"
                                                                                                                          IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                                                                          Command="{Binding SelectCommand}"/>
                                                                                                        </DataTemplate>
                                                                                                    </ItemsControl.ItemTemplate>
                                                                                                </ItemsControl>
                                                                                            </Border>
                                                                                        </Popup>
                                                                                    </StackPanel>
                                                                                    <StackPanel Grid.Column="2" IsVisible="{Binding IsTurbo}" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                                                                        <Button Classes="subtle binding-mini"
                                                                                                Content="-"
                                                                                                Command="{Binding DataContext.DecrRomTurboHzCommand, ElementName=RootWindow}"
                                                                                                CommandParameter="{Binding}"/>
                                                                                        <Border CornerRadius="6" Padding="5,2" Background="#4E3D33" BorderBrush="#8B6E5A" BorderThickness="1" MinWidth="42" VerticalAlignment="Center">
                                                                                            <TextBlock Text="{Binding TurboHzLabel}" FontSize="10" Foreground="#F4EBDD" HorizontalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <Button Classes="subtle binding-mini"
                                                                                                Content="+"
                                                                                                Command="{Binding DataContext.IncrRomTurboHzCommand, ElementName=RootWindow}"
                                                                                                CommandParameter="{Binding}"/>
                                                                                    </StackPanel>
                                                                                    <Border Grid.Column="3"
                                                                                            CornerRadius="6"
                                                                                            BorderThickness="1"
                                                                                            BorderBrush="#8D8174"
                                                                                            Background="#120F0E"
                                                                                            Padding="5,3"
                                                                                            MinWidth="44"
                                                                                            VerticalAlignment="Center"
                                                                                            Focusable="True"
                                                                                            PointerPressed="OnInputBindingBoxPointerPressed"
                                                                                            GotFocus="OnInputBindingBoxGotFocus"
                                                                                            LostFocus="OnInputBindingBoxLostFocus"
                                                                                            KeyDown="OnInputBindingBoxKeyDown">
                                                                                        <TextBlock Text="{Binding SelectedKeyDisplay}" Foreground="#F7ECDD" HorizontalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <Button Grid.Column="4"
                                                                                            Classes="subtle binding-mini"
                                                                                            Content="删除"
                                                                                            Command="{Binding DataContext.RemoveRomExtraBindingCommand, ElementName=RootWindow}"
                                                                                            CommandParameter="{Binding}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</UserControl>
