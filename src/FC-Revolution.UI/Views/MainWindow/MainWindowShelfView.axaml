<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.MainWindowParts.MainWindowShelfView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
                    <Grid IsVisible="{Binding IsShelfLayoutMode}">
                        <Border CornerRadius="28" Padding="20" BorderBrush="#75543A" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B271B" Offset="0"/>
                                    <GradientStop Color="#2B1C14" Offset="0.6"/>
                                    <GradientStop Color="#21150F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <ScrollViewer x:Name="ShelfScrollViewer"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <Viewbox Margin="0,0,0,10"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Top"
                                             Stretch="Uniform"
                                             StretchDirection="Both">
                                        <Grid Width="{Binding ShelfLayoutWidth}"
                                              Height="{Binding ShelfLayoutHeight}">
                                        <Grid IsVisible="{Binding IsClassicBookShelfMode}">
                                                    <Border Margin="10,6,10,6" CornerRadius="20" Background="#241710" BorderBrush="#654731" BorderThickness="1"/>
                                                    <Border Margin="30,12,30,14" Height="18" VerticalAlignment="Top" CornerRadius="9" Background="#7A5639" BorderBrush="#9A7354" BorderThickness="1"/>
                                                    <Border Margin="24,26,24,20" CornerRadius="20" Background="#362318" BorderBrush="#63432C" BorderThickness="1"/>
                                                    <Border Width="18" Margin="22,18,0,20" HorizontalAlignment="Left" Background="#5A3D28" CornerRadius="10"/>
                                                    <Border Width="18" Margin="0,18,22,20" HorizontalAlignment="Right" Background="#5A3D28" CornerRadius="10"/>
                                                    <Grid Margin="30,28,30,26" ColumnDefinitions="*,*,*,*" IsHitTestVisible="False">
                                                        <Border Grid.Column="1"
                                                                Width="16"
                                                                HorizontalAlignment="Left"
                                                                Margin="-8,0,0,0"
                                                                Background="#5E402B"
                                                                BorderBrush="#8A6447"
                                                                BorderThickness="1"
                                                                CornerRadius="8"/>
                                                        <Border Grid.Column="2"
                                                                Width="16"
                                                                HorizontalAlignment="Left"
                                                                Margin="-8,0,0,0"
                                                                Background="#5E402B"
                                                                BorderBrush="#8A6447"
                                                                BorderThickness="1"
                                                                CornerRadius="8"/>
                                                        <Border Grid.Column="3"
                                                                Width="16"
                                                                HorizontalAlignment="Left"
                                                                Margin="-8,0,0,0"
                                                                Background="#5E402B"
                                                                BorderBrush="#8A6447"
                                                                BorderThickness="1"
                                                                CornerRadius="8"/>
                                                        <Border Grid.ColumnSpan="4"
                                                                Height="10"
                                                                VerticalAlignment="Top"
                                                                Margin="10,6,10,0"
                                                                Background="#2B1B12"
                                                                CornerRadius="5"/>
                                                    </Grid>
                                                    <ItemsControl Margin="30,28,30,26"
                                                                  ItemsSource="{Binding ShelfRows}"
                                                                  IsHitTestVisible="False">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Spacing="0"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="model:ShelfRowItem">
                                                                <Grid Height="188">
                                                                    <Border Height="22"
                                                                            Margin="6,0,6,6"
                                                                            VerticalAlignment="Bottom"
                                                                            Background="#6D4C34"
                                                                            BorderBrush="#8C6749"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10"/>
                                                                    <Border Height="5"
                                                                            Margin="18,0,18,21"
                                                                            VerticalAlignment="Bottom"
                                                                            Background="#B38A66"
                                                                            CornerRadius="2.5"
                                                                            Opacity="0.42"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <ItemsControl Margin="30,28,30,26"
                                                                  ItemsSource="{Binding ShelfSlots}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <UniformGrid Columns="4"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="model:ShelfSlotItem">
                                                                <Grid Width="264" Height="182" Margin="2,0,2,6">
                                                                    <Border Margin="18,10,18,18"
                                                                            CornerRadius="18"
                                                                            Background="#2A1B13"
                                                                            BorderBrush="#6D4B34"
                                                                            BorderThickness="1"
                                                                            Opacity="0.55"/>
                                                                    <Border Width="14"
                                                                            Margin="8,14,0,18"
                                                                            HorizontalAlignment="Left"
                                                                            Background="#513523"
                                                                            CornerRadius="7"/>
                                                                    <Border Width="14"
                                                                            Margin="0,14,8,18"
                                                                            HorizontalAlignment="Right"
                                                                            Background="#513523"
                                                                            CornerRadius="7"/>
                                                                    <Button Classes="shelf-card"
                                                                            IsVisible="{Binding HasRom}"
                                                                            Margin="18,10,18,18"
                                                                            Padding="0"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Command="{Binding DataContext.SelectRomCommand, ElementName=RootWindow}"
                                                                            CommandParameter="{Binding Rom}"
                                                                            Tapped="OnShelfSlotTapped"
                                                                            DoubleTapped="OnShelfSlotDoubleTapped">
                                                                        <Button.ContextMenu>
                                                                            <ContextMenu>
                                                                                <MenuItem Header="开始游戏"
                                                                                          Command="{Binding DataContext.PlayRomFromMenuCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="重新生成预览图"
                                                                                          Command="{Binding DataContext.RegeneratePreviewForRomCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="导入预览视频"
                                                                                          Command="{Binding DataContext.ImportPreviewVideoForRomCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="导入封面图"
                                                                                          Command="{Binding DataContext.ImportCoverImageForRomCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="导入附加图片"
                                                                                          Command="{Binding DataContext.ImportArtworkImageForRomCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="编辑独立按键"
                                                                                          Command="{Binding DataContext.OpenRomInputOverrideEditorCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="删除独立按键"
                                                                                          Command="{Binding DataContext.RemoveRomInputOverrideFromMenuCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                                <MenuItem Header="删除游戏"
                                                                                          Command="{Binding DataContext.DeleteRomCommand, ElementName=RootWindow}"
                                                                                          CommandParameter="{Binding Rom}"/>
                                                                            </ContextMenu>
                                                                        </Button.ContextMenu>
                                                                        <Grid Width="228" Height="150">
                                                                            <Border Margin="6,8,6,4"
                                                                                    CornerRadius="18"
                                                                                    Background="#110A08"
                                                                                    Opacity="0.45"/>
                                                                            <Border CornerRadius="16" Background="#5C3D28" BorderBrush="#8B6447" BorderThickness="1"/>
                                                                            <Border Margin="10" CornerRadius="12" Background="#201612"/>
                                                                            <Border Margin="12,12,12,0"
                                                                                    Height="8"
                                                                                    VerticalAlignment="Top"
                                                                                    CornerRadius="4"
                                                                                    Background="#7A5A41"
                                                                                    Opacity="0.7"/>

                                                                            <Grid>
                                                                                <Border Margin="12"
                                                                                        CornerRadius="12"
                                                                                        ClipToBounds="True"
                                                                                        Background="#120D0B">
                                                                                    <Grid>
                                                                                        <Image IsVisible="{Binding Rom.HasPreviewBitmap}"
                                                                                               Source="{Binding Rom.CurrentPreviewBitmap}"
                                                                                               Stretch="Fill"
                                                                                               RenderOptions.BitmapInterpolationMode="None"/>
                                                                                        <Grid IsVisible="{Binding Rom.NoPreviewBitmap}" Background="#211814">
                                                                                            <Viewbox Width="78" Height="46" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                                <Canvas Width="156" Height="92">
                                                                                                    <Border Width="156" Height="92" CornerRadius="18" Background="#E6DED0" BorderBrush="#8E7C68" BorderThickness="4"/>
                                                                                                    <Border Width="44" Height="10" CornerRadius="5" Background="#B1A08D" Margin="56,8,0,0"/>
                                                                                                    <Ellipse Width="26" Height="26" Fill="#A39382" Margin="20,32,0,0"/>
                                                                                                    <Ellipse Width="26" Height="26" Fill="#A39382" Margin="110,32,0,0"/>
                                                                                                    <Border Width="36" Height="12" Background="#5B5148" CornerRadius="4" Margin="16,39,0,0"/>
                                                                                                    <Border Width="12" Height="36" Background="#5B5148" CornerRadius="4" Margin="28,27,0,0"/>
                                                                                                    <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="102,36,0,0"/>
                                                                                                    <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="120,44,0,0"/>
                                                                                                    <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="68,50,0,0"/>
                                                                                                    <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="84,50,0,0"/>
                                                                                                </Canvas>
                                                                                            </Viewbox>
                                                                                        </Grid>
                                                                                    </Grid>
                                                                                </Border>

                                                                                <Border IsVisible="{Binding Rom.IsCurrent}"
                                                                                        CornerRadius="16"
                                                                                        BorderBrush="#F3D9B0"
                                                                                        BorderThickness="3"/>
                                                                                <Border IsVisible="{Binding Rom.IsCurrent}"
                                                                                        Background="#D8B386"
                                                                                        CornerRadius="9"
                                                                                        HorizontalAlignment="Left"
                                                                                        VerticalAlignment="Top"
                                                                                        Margin="10,10,0,0"
                                                                                        Padding="8,4">
                                                                                    <TextBlock Classes="label" FontSize="10" Foreground="#2E1E15" Text="当前"/>
                                                                                </Border>
                                                                                <Border IsVisible="{Binding Rom.IsLoaded}"
                                                                                        Background="#6C4B33"
                                                                                        CornerRadius="12"
                                                                                        HorizontalAlignment="Right"
                                                                                        VerticalAlignment="Top"
                                                                                        Margin="0,10,10,0"
                                                                                        Padding="8,4">
                                                                                    <TextBlock Classes="label" FontSize="10" Text="播放中"/>
                                                                                </Border>

                                                                                <Border VerticalAlignment="Bottom"
                                                                                        Margin="12"
                                                                                        Padding="10,8"
                                                                                        Background="#AA190F0C"
                                                                                        CornerRadius="10">
                                                                                    <StackPanel Spacing="4">
                                                                                        <TextBlock Classes="hero"
                                                                                                   FontSize="15"
                                                                                                   Foreground="#F8EEDC"
                                                                                                   Text="{Binding Rom.ShelfCaption}"
                                                                                                   TextWrapping="Wrap"/>
                                                                                        <TextBlock Classes="label"
                                                                                                   FontSize="11"
                                                                                                   IsVisible="{Binding Rom.PreviewBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                                                   Text="{Binding Rom.PreviewBadge}"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                                <Border IsVisible="{Binding Rom.IsCurrent}"
                                                                                        VerticalAlignment="Bottom"
                                                                                        Margin="12"
                                                                                        Padding="10,8"
                                                                                        BorderBrush="#E1C095"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="10"
                                                                                        Opacity="0.85"/>
                                                                            </Grid>
                                                                        </Grid>
                                                                    </Button>

                                                                    <Grid IsVisible="{Binding IsEmpty}" Margin="18,10,18,18">
                                                                        <Border CornerRadius="16" Background="#2B1D16" BorderBrush="#5D4331" BorderThickness="1"/>
                                                                        <Border Margin="12" CornerRadius="12" Background="#201612" BorderBrush="#4B3326" BorderThickness="1"/>
                                                                        <StackPanel HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Spacing="6">
                                                                            <Ellipse Width="64" Height="64" Fill="#473126" Stroke="#7A5941" StrokeThickness="2"/>
                                                                            <TextBlock Classes="label" FontSize="12" Text="空位" HorizontalAlignment="Center"/>
                                                                            <TextBlock Classes="label" FontSize="10" Text="等待入柜" HorizontalAlignment="Center" Opacity="0.72"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                            </Grid>
                                        </Grid>
                                    </Viewbox>
                                </ScrollViewer>
                                <ScrollBar x:Name="ShelfScrollBar"
                                           Grid.Column="1"
                                           Width="18"
                                           Orientation="Vertical"
                                           Minimum="0"
                                           Maximum="0"
                                           ViewportSize="0"
                                           Background="#1D1410"
                                           Foreground="#C8A67E"/>
                            </Grid>
                        </Border>
                    </Grid>
</UserControl>
