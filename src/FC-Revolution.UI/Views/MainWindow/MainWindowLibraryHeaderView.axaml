<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.MainWindowParts.MainWindowLibraryHeaderView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
<Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="hero" FontSize="30" Text="{Binding CurrentRomName}"/>
                        <TextBlock Classes="label" FontSize="12" Text="{Binding LibrarySummary}"/>
                    </StackPanel>

                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="3"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6">
                            <TextBlock Classes="caption" VerticalAlignment="Center" Text="布局"/>
                            <ToggleButton Grid.Column="1"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="书柜"
                                          Command="{Binding UseBookShelfLayoutCommand}"
                                          IsChecked="{Binding IsBookShelfMode, Mode=OneWay}"/>
                            <ToggleButton Grid.Column="2"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="列表"
                                          Command="{Binding UseCarouselLayoutCommand}"
                                          IsChecked="{Binding IsCarouselMode, Mode=OneWay}"/>
                            <ToggleButton Grid.Column="3"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="万花筒"
                                          Command="{Binding UseKaleidoscopeLayoutCommand}"
                                          IsChecked="{Binding IsKaleidoscopeMode, Mode=OneWay}"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                            <TextBlock Classes="caption" VerticalAlignment="Center" Text="排序"/>
                            <ToggleButton Grid.Column="1"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="名称"
                                          Command="{Binding SortByNameCommand}"
                                          IsChecked="{Binding IsSortByName, Mode=OneWay}"/>
                            <ToggleButton Grid.Column="2"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="大小"
                                          Command="{Binding SortBySizeCommand}"
                                          IsChecked="{Binding IsSortBySize, Mode=OneWay}"/>
                            <ToggleButton Grid.Column="3"
                                          Classes="panel-action mode-toggle header-compact"
                                          Content="时间"
                                          Command="{Binding SortByImportedAtCommand}"
                                          IsChecked="{Binding IsSortByImportedAt, Mode=OneWay}"/>
                            <Button Grid.Column="4"
                                    Classes="panel-action header-compact"
                                    Content="{Binding SortDirectionCompactText}"
                                    Command="{Binding ToggleSortDirectionCommand}"/>
                        </Grid>
                    </Grid>
                </Grid>

                <Border Grid.Row="1"
                        CornerRadius="22"
                        Padding="14,10"
                        BorderBrush="#5B4130"
                        BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#241813" Offset="0"/>
                            <GradientStop Color="#19110D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="240,*,Auto" ColumnSpacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                            <TextBox Classes="toolbar-search"
                                     Text="{Binding LibrarySearchText}"
                                     Watermark="搜索标题或文件名"/>
                            <Button Grid.Column="1"
                                    Classes="subtle action-compact"
                                    Content="清除"
                                    Command="{Binding ClearLibrarySearchCommand}"
                                    IsVisible="{Binding HasLibrarySearchText}"/>
                        </Grid>

                        <TextBlock Grid.Column="1"
                                   Classes="label"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentRomActionSummary}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Classes="chrome action-compact"
                                    Content="开始游戏"
                                    Command="{Binding PlaySelectedRomCommand}"
                                    IsEnabled="{Binding CanPlaySelectedRom}"/>
                            <Button Classes="subtle action-compact"
                                    Content="{Binding PreviewQuickActionText}"
                                    Command="{Binding GeneratePreviewCommand}"
                                    IsEnabled="{Binding CanGeneratePreview}"/>
                            <Button Classes="subtle action-compact"
                                    Content="分支画廊"
                                    Command="{Binding OpenBranchGalleryCommand}"
                                    IsEnabled="{Binding HasCurrentRom}"/>
                            <Button Classes="subtle action-compact"
                                    Content="独立按键"
                                    Command="{Binding OpenRomInputOverrideEditorCommand}"
                                    CommandParameter="{Binding CurrentRom}"
                                    IsEnabled="{Binding HasCurrentRom}"/>
                            <Button Classes="subtle action-compact"
                                    Content="游戏设置"
                                    Command="{Binding ToggleSettingsCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
</Grid>
</UserControl>
