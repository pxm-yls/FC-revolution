<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FC_Revolution.UI.ViewModels"
             xmlns:model="using:FC_Revolution.UI.Models"
             x:Class="FC_Revolution.UI.Views.MainWindowParts.MainWindowKaleidoscopeView"
             x:Name="RootWindow"
             x:DataType="vm:MainWindowViewModel">
                    <Grid IsVisible="{Binding IsKaleidoscopeMode}">
                        <Border CornerRadius="28" Padding="22" BorderBrush="#75543A" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#221611" Offset="0"/>
                                    <GradientStop Color="#17100D" Offset="0.65"/>
                                    <GradientStop Color="#0F0A08" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                                <Border CornerRadius="26" Background="#1A120F" BorderBrush="#5E4636" BorderThickness="1" Padding="18" ClipToBounds="True">
                                    <Grid>
                                        <Grid.DataTemplates>
                                            <DataTemplate x:DataType="model:KaleidoscopeSlotItem">
                                                <Grid Width="{Binding Width}" Height="{Binding Height}">
                                                    <Border IsVisible="{Binding HasRom}"
                                                            CornerRadius="18"
                                                            Background="#241914"
                                                            BorderBrush="#6E533E"
                                                            BorderThickness="1"/>
                                                    <Button IsVisible="{Binding HasRom}"
                                                            Classes="shelf-card"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Command="{Binding DataContext.SelectKaleidoscopeRomCommand, ElementName=RootWindow}"
                                                            CommandParameter="{Binding}"
                                                            Tapped="OnShelfSlotTapped"
                                                            DoubleTapped="OnShelfSlotDoubleTapped">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="开始游戏"
                                                                          Command="{Binding DataContext.PlayRomFromMenuCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="重新生成预览图"
                                                                          Command="{Binding DataContext.RegeneratePreviewForRomCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="导入预览视频"
                                                                          Command="{Binding DataContext.ImportPreviewVideoForRomCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="导入封面图"
                                                                          Command="{Binding DataContext.ImportCoverImageForRomCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="导入附加图片"
                                                                          Command="{Binding DataContext.ImportArtworkImageForRomCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="编辑独立按键"
                                                                          Command="{Binding DataContext.OpenRomInputOverrideEditorCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="删除独立按键"
                                                                          Command="{Binding DataContext.RemoveRomInputOverrideFromMenuCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                                <MenuItem Header="删除游戏"
                                                                          Command="{Binding DataContext.DeleteRomCommand, ElementName=RootWindow}"
                                                                          CommandParameter="{Binding Rom}"/>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <Grid Margin="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                                            <Border CornerRadius="16" Background="#4F3728" BorderBrush="#8B6549" BorderThickness="1"/>
                                                            <Border Margin="8" CornerRadius="12" Background="#120D0B" ClipToBounds="True">
                                                                <Grid>
                                                                    <Image IsVisible="{Binding Rom.HasPreviewBitmap}"
                                                                           Source="{Binding Rom.CurrentPreviewBitmap}"
                                                                           Stretch="Fill"
                                                                           RenderOptions.BitmapInterpolationMode="None"/>
                                                                    <Grid IsVisible="{Binding Rom.NoPreviewBitmap}" Background="#211814">
                                                                        <Viewbox Width="62" Height="36" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <Canvas Width="156" Height="92">
                                                                                <Border Width="156" Height="92" CornerRadius="18" Background="#E6DED0" BorderBrush="#8E7C68" BorderThickness="4"/>
                                                                                <Border Width="44" Height="10" CornerRadius="5" Background="#B1A08D" Margin="56,8,0,0"/>
                                                                                <Ellipse Width="26" Height="26" Fill="#A39382" Margin="20,32,0,0"/>
                                                                                <Ellipse Width="26" Height="26" Fill="#A39382" Margin="110,32,0,0"/>
                                                                                <Border Width="36" Height="12" Background="#5B5148" CornerRadius="4" Margin="16,39,0,0"/>
                                                                                <Border Width="12" Height="36" Background="#5B5148" CornerRadius="4" Margin="28,27,0,0"/>
                                                                                <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="102,36,0,0"/>
                                                                                <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="120,44,0,0"/>
                                                                                <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="68,50,0,0"/>
                                                                                <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="84,50,0,0"/>
                                                                            </Canvas>
                                                                        </Viewbox>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>
                                                            <Border IsVisible="{Binding Rom.IsCurrent}"
                                                                    CornerRadius="16"
                                                                    BorderBrush="#F3D9B0"
                                                                    BorderThickness="3"/>
                                                            <Border VerticalAlignment="Bottom"
                                                                    HorizontalAlignment="Stretch"
                                                                    MinHeight="42"
                                                                    Margin="10"
                                                                    Padding="8,6"
                                                                    Background="#B316120F"
                                                                    CornerRadius="10">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Classes="hero"
                                                                               FontSize="13"
                                                                               Foreground="#F8EEDC"
                                                                               MaxLines="1"
                                                                               Text="{Binding Rom.ShelfCaption}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               TextWrapping="NoWrap"/>
                                                                    <TextBlock Classes="label" FontSize="10"
                                                                               IsVisible="{Binding Rom.PreviewBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                               Text="{Binding Rom.PreviewBadge}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Button>

                                                    <Grid IsVisible="{Binding IsEmpty}" Margin="8">
                                                        <Border CornerRadius="16" Background="#1A120F" BorderBrush="#4B372B" BorderThickness="1"/>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                                                            <Ellipse Width="42" Height="42" Fill="#36251D" Stroke="#7A5D49" StrokeThickness="2"/>
                                                            <TextBlock Classes="label" FontSize="11" Text="空位" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </DataTemplate>
                                        </Grid.DataTemplates>
                                        <Canvas Width="940" Height="600"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Rectangle Width="220"
                                                       Height="2"
                                                       RadiusX="1"
                                                       RadiusY="1"
                                                       Fill="#66D8B083"
                                                       Canvas.Left="{Binding KaleidoscopeSweepOffset}"
                                                       Canvas.Top="{Binding KaleidoscopeSweepTop}"
                                                       Opacity="{Binding KaleidoscopePulseOpacity}"
                                                       IsHitTestVisible="False"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="{Binding KaleidoscopeSweepAngle}"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="170"
                                                       Height="2"
                                                       RadiusX="1"
                                                       RadiusY="1"
                                                       Fill="#44F1D0A6"
                                                       Canvas.Left="{Binding KaleidoscopeSweepOffsetSecondary}"
                                                       Canvas.Top="{Binding KaleidoscopeSweepTopSecondary}"
                                                       Opacity="{Binding KaleidoscopePulseOpacity}"
                                                       IsHitTestVisible="False"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="{Binding KaleidoscopeSweepAngleSecondary}"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Ellipse Width="14"
                                                     Height="14"
                                                     Fill="#88F4D7B6"
                                                     Canvas.Left="{Binding KaleidoscopeOrbitDotX}"
                                                     Canvas.Top="{Binding KaleidoscopeOrbitDotY}"
                                                     Opacity="{Binding KaleidoscopePulseOpacity}"
                                                     IsHitTestVisible="False"/>
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Fill="#66CDAA7F"
                                                     Canvas.Left="{Binding KaleidoscopeOrbitDotSecondaryX}"
                                                     Canvas.Top="{Binding KaleidoscopeOrbitDotSecondaryY}"
                                                     Opacity="{Binding KaleidoscopePulseOpacity}"
                                                     IsHitTestVisible="False"/>
                                                <Polygon Points="470,16 714,90 816,300 714,510 470,584 226,510 124,300 226,90"
                                                         Stroke="#7C5D45"
                                                         StrokeThickness="4"
                                                         Fill="#120D0B"
                                                         IsHitTestVisible="False"/>
                                                <Polygon Points="470,54 676,118 760,300 676,482 470,546 264,482 180,300 264,118"
                                                         Stroke="#4B372B"
                                                         StrokeThickness="2"
                                                         Fill="#0A0706"
                                                         IsHitTestVisible="False"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot0.X}" Canvas.Top="{Binding KaleidoscopeSlot0.Y}" Content="{Binding KaleidoscopeSlot0}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot1.X}" Canvas.Top="{Binding KaleidoscopeSlot1.Y}" Content="{Binding KaleidoscopeSlot1}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot2.X}" Canvas.Top="{Binding KaleidoscopeSlot2.Y}" Content="{Binding KaleidoscopeSlot2}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot3.X}" Canvas.Top="{Binding KaleidoscopeSlot3.Y}" Content="{Binding KaleidoscopeSlot3}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot4.X}" Canvas.Top="{Binding KaleidoscopeSlot4.Y}" Content="{Binding KaleidoscopeSlot4}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot5.X}" Canvas.Top="{Binding KaleidoscopeSlot5.Y}" Content="{Binding KaleidoscopeSlot5}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot6.X}" Canvas.Top="{Binding KaleidoscopeSlot6.Y}" Content="{Binding KaleidoscopeSlot6}"/>
                                            <ContentControl Canvas.Left="{Binding KaleidoscopeSlot7.X}" Canvas.Top="{Binding KaleidoscopeSlot7.Y}" Content="{Binding KaleidoscopeSlot7}"/>
                                        </Canvas>

                                        <Button Width="396"
                                                Height="258"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding PlaySelectedRomCommand}"
                                                IsEnabled="{Binding CanPlaySelectedRom}">
                                            <Border CornerRadius="26"
                                                    Background="#211713"
                                                    BorderBrush="#A57D59"
                                                    BorderThickness="2"
                                                    Padding="18">
                                                <Border CornerRadius="18"
                                                        Background="#120D0B"
                                                        BorderBrush="#5E4636"
                                                        BorderThickness="1"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image IsVisible="{Binding HasDiscDisplayBitmap}"
                                                               Source="{Binding DiscDisplayBitmap}"
                                                               Stretch="Fill"
                                                               RenderOptions.BitmapInterpolationMode="None"/>
                                                        <Grid IsVisible="{Binding NoDiscDisplayBitmap}" Background="#211814">
                                                            <Viewbox Width="160" Height="94" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Canvas Width="156" Height="92">
                                                                    <Border Width="156" Height="92" CornerRadius="18" Background="#E6DED0" BorderBrush="#8E7C68" BorderThickness="4"/>
                                                                    <Border Width="44" Height="10" CornerRadius="5" Background="#B1A08D" Margin="56,8,0,0"/>
                                                                    <Ellipse Width="26" Height="26" Fill="#A39382" Margin="20,32,0,0"/>
                                                                    <Ellipse Width="26" Height="26" Fill="#A39382" Margin="110,32,0,0"/>
                                                                    <Border Width="36" Height="12" Background="#5B5148" CornerRadius="4" Margin="16,39,0,0"/>
                                                                    <Border Width="12" Height="36" Background="#5B5148" CornerRadius="4" Margin="28,27,0,0"/>
                                                                    <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="102,36,0,0"/>
                                                                    <Ellipse Width="14" Height="14" Fill="#C15D51" Margin="120,44,0,0"/>
                                                                    <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="68,50,0,0"/>
                                                                    <Ellipse Width="10" Height="10" Fill="#8E8174" Margin="84,50,0,0"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Grid>
                                                        <Border IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#2AF7E2C7" Offset="0"/>
                                                                    <GradientStop Color="#08FFFFFF" Offset="0.45"/>
                                                                    <GradientStop Color="#2A130F0C" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Border>
                                        </Button>

                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Width="82"
                                        Padding="8"
                                        CornerRadius="18"
                                        Background="#1A120F"
                                        BorderBrush="#5E4636"
                                        BorderThickness="1"
                                        IsVisible="{Binding HasKaleidoscopePagination}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding KaleidoscopePages}"
                                                      HorizontalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical" Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="model:KaleidoscopePageItem">
                                                    <Grid Width="46"
                                                          Height="34"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center">
                                                        <Border IsVisible="{Binding IsCurrent}"
                                                                Width="46"
                                                                Height="34"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                BorderBrush="#E6C196"
                                                                BorderThickness="2"
                                                                CornerRadius="12"
                                                                IsHitTestVisible="False"/>
                                                        <Button Classes="kaleido-page"
                                                                Content="{Binding Label}"
                                                                Command="{Binding DataContext.SelectKaleidoscopePageCommand, ElementName=RootWindow}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
</UserControl>
